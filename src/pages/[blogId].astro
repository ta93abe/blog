---
import Layout from "../layouts/Layout.astro";
import { getBlogs, getBlogDetail } from "../lib/microcms";
import "../css/base.css";

export async function getStaticPaths() {
  const response = await getBlogs({ fields: ["id"] });
  return response.contents.map((content: any) => ({
    params: {
      blogId: content.id,
    },
  }));
}

export const prerender = true;

//記事の詳細情報を取得
const { blogId } = Astro.params;
const blog = await getBlogDetail(blogId as string);
---

<Layout title={blog.title}>
  <main class="flex flex-col gap-4">
    <img src={blog.eyecatch.url} width={blog.eyecatch.width} height={blog.eyecatch.height} alt="eyecatch" />
    <h1 class="text-4xl font-bold">{blog.title}</h1>
    <p class="flex justify-end">{blog.publishedAt.split('T')[0]}</p>
    <div set:html={blog.content}></div>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding: 1em;
    max-width: 60ch;
  }
</style>